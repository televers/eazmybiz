# Copy to `.env.local` (Next.js) — never commit real secrets.
# Razorpay: https://dashboard.razorpay.com/

# Server only (orders + signature verify)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Webhook HMAC (different from Key Secret) — `POST /api/webhooks/razorpay`
RAZORPAY_WEBHOOK_SECRET=

# Client Checkout (Key Id only; must match RAZORPAY_KEY_ID in normal setups)
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Optional: `live` | `test` (informational)
# RAZORPAY_ENV=test
